FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database — defaults to local SQLite file (taskflow.db)
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost/taskflow
DATABASE_URL=

# Optional: OpenAI API key for GPT-4o-mini powered summaries
# Leave blank to use the deterministic heuristic fallback (fully functional)
OPENAI_API_KEY=

LOG_LEVEL=INFO
