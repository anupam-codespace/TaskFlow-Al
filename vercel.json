{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend"
    },
    "backend": {
      "entrypoint": "backend/run.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/run.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
